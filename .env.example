# Voxentia — copy to .env and adjust for local development
# Docker Compose overrides DB_PATH, OLLAMA_URL, TTS_URL, WHISPER_URL automatically.

# --- Database ---
# Local dev default (SQLite). In Docker, compose sets Postgres:
# DB_PATH=postgresql+psycopg2://user:pass@db:5432/voxentia
DB_PATH=sqlite:///./data/chat.db

POSTGRES_USER=user
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=voxentia

USER_FINGERPRINT=

# --- LLM & voice ---
OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=phi3
TTS_URL=http://localhost:5002
WHISPER_URL=http://localhost:5003

# --- Server ---
UVICORN_WORKERS=1
# REDIS_URL=redis://redis:6379/0  # enable with: docker compose --profile redis up
REDIS_URL=
RATE_LIMIT=60/minute

LOG_LEVEL=INFO
LOG_FORMAT=text
ENABLE_METRICS=true

AUTH_ENABLED=false
API_KEY=
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173

# --- Event bus (Redis Streams) ---
ENABLE_EVENT_BUS=false
# Docker default: redis://redis:6379/0

# --- OpenTelemetry tracing ---
ENABLE_TRACING=true
OTEL_SERVICE_NAME=voxentia-backend
# OTLP collector, e.g. Jaeger: http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_CONSOLE_EXPORT=false
